# DeepSeek 配置
export DEEPSEEK_API_KEY=your_api_key
export DEEPSEEK_MODEL=deepseek-v4-pro
export DEEPSEEK_BASE_URL=https://api.deepseek.com

# 服务监听配置
# SERVER_PORT 只配置端口，默认 8080。
export SERVER_PORT=8080
# SERVER_ADDR 配置完整监听地址；如果启用，会优先于 SERVER_PORT。
# 示例：
# export SERVER_ADDR=:8080
# export SERVER_ADDR=127.0.0.1:8080

# 数据与日志路径
export DATABASE_PATH=data/project-helper.db
export REPOS_DIR=data/repos
export REPORTS_DIR=data/reports
export LOG_PATH=data/logs/server.log

# 开发模式前端地址，用于 CORS；生产单二进制模式通常不用改。
export FRONTEND_URL=http://localhost:5173
